# SAM3 model ID on HuggingFace
SAM3_MODEL_ID=facebook/sam3

# Device: cuda, mps, or cpu
DEVICE=cpu

# Detection confidence threshold (0.0 - 1.0)
DETECTION_THRESHOLD=0.5

# Mask threshold for post-processing
MASK_THRESHOLD=0.5

# For video: how many frames per second to analyze (lower = faster)
ANALYZE_FPS=2

# For RTSP/camera streams: how many seconds to capture and analyze
STREAM_CAPTURE_SECONDS=10

# Movement detection: minimum pixel displacement between frames to count as moving
MOVEMENT_THRESHOLD_PX=15
